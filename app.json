{
  "expo": {
    "name": "Grocery Plus",
    "slug": "GroceryPlus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/GroceryPlus.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ]
    ],
    "splash": {
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/GroceryPlus.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/GroceryPlus.png"
    }
    
  }
}
